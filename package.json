{
  "name": "archilang",
  "version": "0.1.0",
  "description": "ARCHILANG YAML to SVG floor plan renderer",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "render": "node dist/main.js",
    "render:sample": "node dist/main.js samples/$npm_config_name.yaml samples/$npm_config_name.svg",
    "dev": "tsc --watch",
    "validate": "node dist/main.js validate",
    "watch": "node dist/main.js watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
